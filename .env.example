# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://orgforge:password@localhost:5432/orgforge

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET=orgforge-metadata

# ── Salesforce OAuth ──────────────────────────────────────────────────────────
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_CALLBACK_URL=http://localhost:8000/api/auth/sf/callback

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/api/auth/github/callback

# ── Jira OAuth ────────────────────────────────────────────────────────────────
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_CALLBACK_URL=http://localhost:8000/api/auth/jira/callback

# ── Claude AI ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
